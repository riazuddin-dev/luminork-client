# Luminork Client — environment variables
# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# On Vercel: set these in Project → Settings → Environment Variables
# (Production + Preview as needed). Never commit real secrets.

# Public API base URL (must include the /api suffix)
# Local:
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Production example (after server is deployed on Render/Railway):
# NEXT_PUBLIC_API_URL=https://luminork-server.onrender.com/api
