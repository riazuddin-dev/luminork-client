# Luminork Client — environment variables
# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# Production URL is also in .env.production (used on Vercel builds).
# You may still set the same value in Vercel → Environment Variables.

# Local development:
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Production API (live server):
# NEXT_PUBLIC_API_URL=https://luminork-server.vercel.app
# (client appends /api automatically if missing)

# Optional: canonical site URL
# NEXT_PUBLIC_SITE_URL=https://luminork-client.vercel.app
