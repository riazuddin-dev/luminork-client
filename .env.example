# Luminork Client — environment variables
# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# On Vercel (https://luminork-client.vercel.app):
#   Project → Settings → Environment Variables
#   Set for Production (and Preview if needed), then Redeploy.

# ---------------------------------------------------------------------------
# REQUIRED for production — public API base (must end with /api)
# ---------------------------------------------------------------------------
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Production (set in Vercel dashboard — replace with your live server URL):
# NEXT_PUBLIC_API_URL=https://YOUR-API-HOST.onrender.com/api
# NEXT_PUBLIC_API_URL=https://YOUR-API-HOST.up.railway.app/api
#
# Tip: you can also set just the origin; the client normalizes to .../api:
# NEXT_PUBLIC_API_URL=https://YOUR-API-HOST.onrender.com

# Optional: canonical site URL for SEO / absolute links
# NEXT_PUBLIC_SITE_URL=https://luminork-client.vercel.app
